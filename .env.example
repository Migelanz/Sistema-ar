# Copia este archivo a .env y rellena con tus valores reales.
# NUNCA subas .env al repositorio.

# Token de servicio de Grafana (rótalo si alguna vez se expuso)
GRAFANA_TOKEN=

# Clave para firmar los JWT. Genera una larga y aleatoria, p.ej.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRET_KEY=

# Credenciales del único usuario administrador
ADMIN_USER=
ADMIN_PASS=

# Opcionales (tienen valor por defecto en server.js)
# PORT=3001
# GRAFANA_URL=http://192.168.106.218:3000
# MYSQL_UID=fez96jtiy7kzka
